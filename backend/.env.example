# Copy this file to `.env` (in the same backend/ folder) and fill in your key.
# `.env` is git-ignored so your key is never committed.
#
#   cp .env.example .env      # then edit .env and paste your key
#
# Get a key at https://console.anthropic.com/ → API keys.
ANTHROPIC_API_KEY=

# Optional — which Claude model powers the AI features. Defaults to
# claude-opus-4-8. Use claude-haiku-4-5 for cheaper/faster (some quality cost).
# ANTHROPIC_MODEL=claude-opus-4-8

# Optional — general-retail barcode lookups (non-food products: electronics,
# household goods, cosmetics). WITHOUT these keys the scan feature still works:
# it uses UPCitemdb's keyless trial endpoint (~100 lookups/day per IP), plenty
# for a demo. Set a key only if you hit that limit.
#
# UPCitemdb: switches from the trial to the authenticated endpoint (higher
# limits). Paid only — DEV plan from https://devs.upcitemdb.com/signup
# UPCITEMDB_KEY=
#
# Go-UPC: a second general-retail fallback, queried only when UPCitemdb misses.
# Dormant unless set. Key from https://go-upc.com/api
# GOUPC_KEY=
